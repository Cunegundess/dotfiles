font-family = JetBrains Mono Nerd Font
# font-family = GeistMono NF
# font-family = DankMono Nerd Font
# font-family = SF Mono
# font-family = Cascadia Code NF
# font-family = Iosevka Nerd Font

font-size = 12
font-style = Regular
font-style-bold = Bold
font-style-italic = Italic
font-style-bold-italic = Bold Italic
# font-thicken = true

# theme = Atom
# theme = carbonfox
# theme = GitHub Dark High Contrast
# theme = GitHub-Dark-Default
# theme = GitHub Light Colorblind
# theme = vesper
# theme = vesper-light
# theme = tokyonight_night
# theme = Kanagawa Wave
theme = Catppuccin Mocha
# theme = dark:GruvboxDarkHard,light:GruvboxLightHard
# theme = vague
# theme = detuned

background-opacity = 1
# window-decoration = client
window-decoration = server
# window-padding-x = 20
# window-padding-y = 20
window-colorspace = "display-p3"

adjust-cell-height = "10%"
copy-on-select = clipboard
shell-integration-features = true
auto-update = check
auto-update-channel = stable
confirm-close-surface = false

keybind = ctrl+space>h=goto_split:left
keybind = ctrl+space>j=goto_split:down
keybind = ctrl+space>k=goto_split:up
keybind = ctrl+space>l=goto_split:right
keybind = ctrl+space>v=new_split:right
keybind = ctrl+space>s=new_split:down
keybind = ctrl+space>shift+h=resize_split:left,10
keybind = ctrl+space>shift+j=resize_split:down,10
keybind = ctrl+space>shift+k=resize_split:up,10
keybind = ctrl+space>shift+l=resize_split:right,10
keybind = ctrl+space>c=new_tab
keybind = ctrl+space>n=next_tab
keybind = ctrl+space>p=previous_tab
keybind = ctrl+space>w=close_surface
keybind = ctrl+space>space=last_tab
keybind = ctrl+space>equal=equalize_splits
keybind = ctrl+space>z=toggle_split_zoom
keybind = ctrl+space>one=goto_tab:1
keybind = ctrl+space>two=goto_tab:2
keybind = ctrl+space>three=goto_tab:3
keybind = ctrl+space>four=goto_tab:4
keybind = ctrl+space>five=goto_tab:5
keybind = ctrl+space>six=goto_tab:6
keybind = ctrl+space>seven=goto_tab:7
keybind = ctrl+space>eight=goto_tab:8
keybind = ctrl+space>nine=goto_tab:9
