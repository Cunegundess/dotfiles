[
  // Navegacao de panes como vim-tmux-navigator
  // Neovim: <C-h/j/k/l> no modo normal e visual
  {
    "context": "VimControl && !menu",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",
      // File finder (Neovim: <leader>ff -> fzf-lua.files)
      "space f": "file_finder::Toggle",
      // Live grep project search (Neovim: <leader>fw -> fzf-lua.live_grep)
      "space f w": ["pane::DeploySearch", { "replace_enabled": true }],
      // Buffer/tab switcher (Neovim: <leader><leader> -> fzf-lua.buffers)
      "space space": "tab_switcher::Toggle",
      // Project panel toggle (Neovim: <leader>e -> Otree)
      "space e": "project_panel::ToggleFocus",
      // Fechar buffer/aba (Neovim: <leader>bd -> mini.bufremove.delete)
      "space w": ["pane::CloseActiveItem", { "close_pinned": false }],
      // Terminal toggle
      "ctrl-enter": "terminal_panel::Toggle",
      // Git panel (Neovim: <leader>gs -> fzf-lua.git_status)
      "space g s": "git_panel::ToggleFocus",
      "space g S": "git::Diff",
      // Diagnostic panel (Neovim: <leader>q -> diagnostics setloclist)
      "space f d": "diagnostics::Deploy",
      // Theme switcher (Neovim: <leader>ft -> fzf-lua.colorschemes)
      "space f t": "theme_selector::Toggle",
      // Outline panel - simbolos do arquivo (Neovim: <leader>fs -> fzf-lua.document_symbols)
      "space f s": "outline::Toggle",
      // Go to line
      "space g g": "go_to_line::Toggle",
      // Project symbols (Neovim: <leader>fw para simbolos)
      "space p": "project_symbols::Toggle",
    },
  },
  // Navegacao a partir de docks (project panel, terminal, etc.)
  {
    "context": "Dock",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",
    },
  },
]
